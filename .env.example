# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Supabase pooled connection (used by app at runtime)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres?pgbouncer=true"
# Direct connection (used by Prisma migrate — not pooled)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Supabase project settings → API → JWT Secret
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# ─── COOKIES ─────────────────────────────────────────────────────────────────
COOKIE_SECURE="false"       # true in production
COOKIE_DOMAIN=""            # "" in dev; ".counselintake.com" in production

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000"

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT="4000"
NODE_ENV="development"

# ─── AWS S3 ────────────────────────────────────────────────────────────────────
# IAM user with ONLY: s3:PutObject, s3:GetObject, s3:HeadObject, s3:DeleteObject
# Scoped to the counselworks-files-{env} bucket only — nothing else.
AWS_ACCESS_KEY_ID="your-iam-access-key"
AWS_SECRET_ACCESS_KEY="your-iam-secret-key"
AWS_REGION="us-west-2"
S3_BUCKET_NAME="counselworks-files-dev"

# ─── SUPABASE AUTH ────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
# Anon key (public) — used only for password auth endpoint
SUPABASE_ANON_KEY="your-supabase-anon-key"

# ─── ANTHROPIC (Claude) ───────────────────────────────────────────────────────
# Used by src/modules/ai for all Claude-powered endpoints (thread interpretation,
# document classification, summaries, drafts, case health summaries). If unset,
# AI endpoints return graceful fallback responses — the build compiles and the
# portal runs without a key; only AI features degrade.
ANTHROPIC_API_KEY=""
